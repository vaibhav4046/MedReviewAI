# Clerk auth — frontend reads VITE_*, backend reads CLERK_SECRET_KEY (optional, JWKS used by default)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_yourkeyhere
CLERK_SECRET_KEY=sk_test_yourkeyhere

# Groq — LLM extraction
GROQ_API_KEY=gsk_yourkeyhere

# Neon Postgres — analyses storage
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# PubMed — optional, raises rate limit
PUBMED_API_KEY=optionalkeyhere

# Local dev only — point frontend at local FastAPI instead of Vercel rewrite
# VITE_API_BASE=http://localhost:8000
